<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/head', { title: 'Editar Cliente - Pazine Barber' }) %>
</head>
<body class="app-body">
  <%- include('../partials/sidebar', { active: 'clients', userName: userName }) %>

  <main class="main-content">
    <h1>Editar Cliente</h1>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="panel">
      <form action="/clients/<%= client.id %>" method="POST" class="form-grid">
        <div class="form-field">
          <label for="name">Nome *</label>
          <input type="text" id="name" name="name" value="<%= client.name %>" required>
        </div>
        <div class="form-field">
          <label for="phone">Telefone</label>
          <input type="text" id="phone" name="phone" value="<%= client.phone || '' %>">
        </div>
        <div class="form-field">
          <label for="email">E-mail</label>
          <input type="email" id="email" name="email" value="<%= client.email || '' %>">
        </div>
        <div class="form-field">
          <label for="company">Empresa</label>
          <input type="text" id="company" name="company" value="<%= client.company || '' %>">
        </div>
        <div class="form-field">
          <label for="project_name">Serviço</label>
          <input type="text" id="project_name" name="project_name" value="<%= client.project_name || '' %>">
        </div>
        <div class="form-field">
          <label for="project_value">Valor (R$) *</label>
          <input type="number" id="project_value" name="project_value" step="0.01" min="0" value="<%= client.project_value %>" required>
        </div>
        <div class="form-field">
          <label for="status">Status *</label>
          <select id="status" name="status" required>
            <% statusOptions.forEach(function(opt) { %>
              <option value="<%= opt %>" <%= client.status === opt ? 'selected' : '' %>><%= opt %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-field form-field-full">
          <label for="notes">Observações</label>
          <textarea id="notes" name="notes" rows="4"><%= client.notes || '' %></textarea>
        </div>
        <div class="form-actions">
          <a href="/clients" class="btn btn-outline">Cancelar</a>
          <button type="submit" class="btn btn-gold">Salvar Alterações</button>
        </div>
      </form>
    </div>
  </main>
</body>
</html>
