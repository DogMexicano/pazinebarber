<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('partials/head', { title: 'Login - Pazine Barber' }) %>
</head>
<body class="auth-body">
  <div class="auth-card">
    <div class="auth-brand">
      <span class="brand-gold">Pazine</span><span class="brand-white">Barber</span>
    </div>
    <h2>Acesse sua conta</h2>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <form action="/login" method="POST" class="auth-form">
      <label for="email">E-mail</label>
      <input type="email" id="email" name="email" required autofocus>

      <label for="password">Senha</label>
      <input type="password" id="password" name="password" required>

      <button type="submit" class="btn btn-gold btn-full">Entrar</button>
    </form>

    <p class="auth-switch">
      Ainda não tem conta? <a href="/register">Cadastre-se</a>
    </p>
  </div>
</body>
</html>
