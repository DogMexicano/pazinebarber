<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/head', { title: 'Novo Cliente - Pazine Barber' }) %>
</head>
<body class="app-body">
  <%- include('../partials/sidebar', { active: 'new-client', userName: userName }) %>

  <main class="main-content">
    <h1>Novo Cliente</h1>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="panel">
      <form action="/clients" method="POST" class="form-grid">
        <div class="form-field">
          <label for="name">Nome *</label>
          <input type="text" id="name" name="name" required>
        </div>
        <div class="form-field">
          <label for="phone">Telefone</label>
          <input type="text" id="phone" name="phone">
        </div>
        <div class="form-field">
          <label for="email">E-mail</label>
          <input type="email" id="email" name="email">
        </div>
        <div class="form-field">
          <label for="company">Empresa</label>
          <input type="text" id="company" name="company">
        </div>
        <div class="form-field">
          <label for="project_name">Serviço</label>
          <input type="text" id="project_name" name="project_name" placeholder="Ex: Corte + Barba">
        </div>
        <div class="form-field">
          <label for="project_value">Valor (R$) *</label>
          <input type="number" id="project_value" name="project_value" step="0.01" min="0" required>
        </div>
        <div class="form-field">
          <label for="status">Status *</label>
          <select id="status" name="status" required>
            <% statusOptions.forEach(function(opt) { %>
              <option value="<%= opt %>"><%= opt %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-field form-field-full">
          <label for="notes">Observações</label>
          <textarea id="notes" name="notes" rows="4"></textarea>
        </div>
        <div class="form-actions">
          <a href="/clients" class="btn btn-outline">Cancelar</a>
          <button type="submit" class="btn btn-gold">Salvar Cliente</button>
        </div>
      </form>
    </div>
  </main>
</body>
</html>
